# Pacifica (optional — see src/hooks.server.ts for defaults)
# PACIFICA_API_BASE_URL=https://api.pacifica.fi
# PACIFICA_API_AUTHORIZATION=
# PUBLIC_PACIFICA_WS_URL=wss://ws.pacifica.fi/ws

# Live signals list (full URL including path, e.g. https://example.ngrok-free.app/signals)
# PUBLIC_SIGNALS_API_URL=

# Archived signals list (full URL including path, e.g. https://example.ngrok-free.app/archives)
# PUBLIC_ARCHIVES_API_URL=

# Pairs list API origin only (no trailing slash); server fetches {PAIRS_API_BASE_URL}/pairs (15m cache)
# PAIRS_API_BASE_URL=https://xxxx.ngrok-free.app

# Solana JSON-RPC for wallet Connection (browser). If unset, the app uses devnet:
# https://api.devnet.solana.com
# PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
